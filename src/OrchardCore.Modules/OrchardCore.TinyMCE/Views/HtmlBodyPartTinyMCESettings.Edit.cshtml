@model OrchardCore.TinyMCE.ViewModels.TinyMCESettingsViewModel

<div id="@Html.IdFor(m => m)" class="type-part-editor type-part-editor-tinymce">
    <div class="mb-3">
        <label asp-for="Options" class="control-label">@T["TinyMCE Options (JSON)"]</label>
        <span class="hint"><a href="https://www.tiny.cloud/docs/tinymce/latest/configuration-quick-start/" target="_blank">@T["Documentation for options"]</a></span>
        <textarea asp-for="Options" class="form-control" autofocus="autofocus" rows="15"></textarea>
    </div>
</div>
<style asp-name="codemirror"></style>
<script asp-name="codemirror" at="Foot"></script>
<script asp-name="codemirror-addon-display-autorefresh" at="Foot"></script>
<script asp-name="codemirror-mode-javascript" at="Foot"></script>
<script asp-name="tinymce-default-settings" at="Foot" depends-on="jQuery"></script>

<script at="Foot" depends-on="jQuery">
    $(function () {
        var optionsTextArea = document.getElementById('@Html.IdFor(x => x.Options)');
        var editor = CodeMirror.fromTextArea(optionsTextArea, {
            autoRefresh: true,
            lineNumbers: true,
            lineWrapping: true,
            matchBrackets: true,
            mode: { name: "javascript" }
        });
    @{
        if (string.IsNullOrEmpty(Model.Options))
        {
            <text>
            if (window.orchardTinyMceDefaults)
            {
                var jsonString = JSON.stringify(window.orchardTinyMceDefaults, null, 4);
                editor.setValue(jsonString);
            }
            </text>
        }
    }
    });
</script>